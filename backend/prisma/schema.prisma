generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ORGANIZATION

model Organization {
  id            String        @id @default(uuid())
  orgName       String
  firstName     String
  surname       String
  email         String        @unique
  password      String        // always store hashed, never plain text
  country       ASEANCountry  @default(Philippines)
  isVerified    Boolean       @default(false)
  status        AccountStatus @default(Pending)
  createdAt     DateTime      @default(now())

  posts         Post[]
  donorPartners DonorOrganizationPartner[]
}

// DONOR

model Donor {
  id            String        @id @default(uuid())
  firstName     String
  lastName      String
  email         String        @unique
  password      String
  country       ASEANCountry  @default(Philippines)
  isVerified    Boolean       @default(false)
  status        AccountStatus @default(Pending)
  createdAt     DateTime      @default(now())

  partnerOrgs   DonorOrganizationPartner[]
}

// ADMIN

model Admin {
  id        String         @id @default(uuid())
  firstName String
  lastName  String
  email     String         @unique
  password  String         // always store hashed, never plain text
  createdAt DateTime       @default(now())

  auditLogs PostAuditLog[]
}

// POST

model Post {
  id             String              @id @default(uuid())
  orgId          String
  organization   Organization        @relation(fields: [orgId], references: [id])
  projectName    String
  description    String?
  causes         CauseEnum[]
  location       String?
  priority       Priority            @default(Medium)
  overallStatus  PostStatus          @default(Pending)
  startDate      DateTime?
  endDate        DateTime?
  startTime      String?
  endTime        String?
  createdAt      DateTime            @default(now())

  supportOptions PostSupportOption[]
  inKindItems    PostInKindItem[]
  contributions  Contribution[]
  auditLogs      PostAuditLog[]
    documents      DocumentUpload[]
}

// POST AUDIT LOG
// Records every admin action taken on a post.
model PostAuditLog {
  id        String     @id @default(uuid())
  postId    String
  post      Post       @relation(fields: [postId], references: [id], onDelete: Cascade)
  adminId   String
  admin     Admin      @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    PostStatus // the status that was set
  createdAt DateTime   @default(now())
}
  model DocumentUpload {
    id            String          @id @default(uuid())
    postId        String
    post          Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
    fileName      String
    fileType      DocumentType
    filePath      String
    fileSize      Int
    mimeType      String?
    uploadedBy    String
    description   String?
    createdAt     DateTime        @default(now())
  }


// POST SUPPORT OPTION

// Each row represents one support type (Monetary or Volunteer) for a post.
// A post can only have one row per type, enforced by @@unique.
model PostSupportOption {
  id            String        @id @default(uuid())
  postId        String
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  type          SupportType

  // Monetary fields
  targetAmount  Float?
  currentAmount Float         @default(0)

  // Volunteer fields
  targetCount   Int?
  currentCount  Int           @default(0)

  status        SupportStatus @default(Open)

  @@unique([postId, type])
}

// POST IN-KIND ITEM

model PostInKindItem {
  id              String         @id @default(uuid())
  postId          String
  post            Post           @relation(fields: [postId], references: [id], onDelete: Cascade)
  itemName        String
  targetQuantity  Float
  currentQuantity Float          @default(0)
  unit            String?
  status          SupportStatus  @default(Open)

  contributions   Contribution[]
}

// CONTRIBUTION
// Records every donation, whether submitted by a registered donor or manually
// logged by the org on behalf of a walk-in/unregistered donor.
// - donorName is always filled (org types this in for manual entries)
// - partnershipId is null for manual entries, populated for registered donors
model Contribution {
  id             String                    @id @default(uuid())
  donorName      String                    // always filled
  partnershipId  String?                   // null for unregistered donors
  partnership    DonorOrganizationPartner? @relation(fields: [partnershipId], references: [id], onDelete: SetNull)
  postId         String
  post           Post                      @relation(fields: [postId], references: [id], onDelete: Cascade)
  type           SupportType

  // Monetary — only populated when type = Monetary
  amount         Float?

  // Volunteer — only populated when type = Volunteer
  volunteerCount Int?

  // InKind — only populated when type = InKind
  inKindItemId   String?
  inKindItem     PostInKindItem?           @relation(fields: [inKindItemId], references: [id], onDelete: SetNull)
  quantity       Float?

  status         ContributionStatus        @default(Pending)
  createdAt      DateTime                  @default(now())
}

// DONOR ORGANIZATION PARTNER
// Represents an ongoing relationship between a registered donor and an org.
// Created when a registered donor's contribution is confirmed.
// contributions[] holds all confirmed contributions made by this donor to this org.
model DonorOrganizationPartner {
  id             String         @id @default(uuid())
  donorId        String
  donor          Donor          @relation(fields: [donorId], references: [id], onDelete: Cascade)
  orgId          String
  organization   Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  contributions  Contribution[]

  @@unique([donorId, orgId])
}

// PASSWORD RESET TOKEN
// Stores temporary tokens for password reset requests.
// Tokens expire after 24 hours and are deleted after use.
model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String   // email of user requesting password reset
  token     String   @unique // unique reset token
  expiresAt DateTime // expiration timestamp (24 hours from creation)
  isUsed    Boolean  @default(false) // marked true after password is successfully reset
  createdAt DateTime @default(now())
}

// ENUMS

enum ASEANCountry {
  Brunei
  Cambodia
  Indonesia
  Laos
  Malaysia
  Myanmar
  Philippines
  Singapore
  Thailand
  Vietnam
}

enum SupportType {
  Monetary
  Volunteer
  InKind
}

enum CauseEnum {
  noPoverty                   // SDG 1  — No Poverty
  zeroHunger                  // SDG 2  — Zero Hunger
  goodHealth                  // SDG 3  — Good Health and Well-being
  qualityEducation            // SDG 4  — Quality Education
  genderEquality              // SDG 5  — Gender Equality
  cleanWater                  // SDG 6  — Clean Water and Sanitation
  affordableEnergy            // SDG 7  — Affordable and Clean Energy
  decentWork                  // SDG 8  — Decent Work and Economic Growth
  industry                    // SDG 9  — Industry, Innovation and Infrastructure
  reducedInequalities         // SDG 10 — Reduced Inequalities
  sustainableCities           // SDG 11 — Sustainable Cities and Communities
  responsibleConsumption      // SDG 12 — Responsible Consumption and Production
  climateAction               // SDG 13 — Climate Action
  lifeBelowWater              // SDG 14 — Life Below Water
  lifeOnLand                  // SDG 15 — Life on Land
  peaceAndJustice             // SDG 16 — Peace, Justice and Strong Institutions
  partnerships                // SDG 17 — Partnerships for the Goals
  others
}

enum Priority {
  High
  Medium
  Low
}

enum PostStatus {
  Pending
  Approved
  Unapproved
  Edited
  Deleted
}

enum SupportStatus {
  Open
  Closed
}

enum AccountStatus {
  Pending   // just registered, not yet reviewed
  Approved  // verified and active
  Rejected  // denied by admin
  Active    // approved and currently active
}

enum ContributionStatus {
  Pending    // logged, waiting for org to confirm
  Confirmed  // org verified the contribution
  Declined   // org rejected the contribution
  }

  enum DocumentType {
    Photo
    Receipt
    Report
    Update
    Certificate
    Other
}
