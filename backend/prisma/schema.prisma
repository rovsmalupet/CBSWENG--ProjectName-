generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String        @id @default(uuid())
  firstName            String
  surname              String
  email                String        @unique
  password             String
  role                 UserRole
  status               AccountStatus @default(active)
  affiliation          String?
  representativePerson String?
  isVerified           Boolean       @default(false)
  createdAt            DateTime      @default(now())
}

model Organization {
  id                   String   @id @default(uuid())
  orgName              String
  firstName            String
  surname              String
  email                String   @unique
  isVerified           Boolean  @default(false)
  status               String   @default("pending")
  createdAt            DateTime @default(now())
  posts                Post[]   
}

model Post {
  id            String        @id @default(uuid())
  orgId         String        
  organization  Organization  @relation(fields: [orgId], references: [id])
  projectName   String
  description   String?
  causes        CauseEnum[]
  location      String?
  priority      Priority      @default(Medium)
  overallStatus PostStatus    @default(Pending)
  createdAt     DateTime      @default(now())
  startDate     String?
  endDate       String?
  monetaryEnabled       Boolean       @default(false)
  monetaryTargetAmount  Float?
  monetaryCurrentAmount Float         @default(0)
  monetaryStatus        SupportStatus @default(Open)
  volunteerEnabled      Boolean       @default(false)
  volunteerTargetCount  Int?
  volunteerCurrentCount Int           @default(0)
  volunteerStatus       SupportStatus @default(Open)
  inKindItems PostInKindItem[]
}

model PostInKindItem {
  id              String        @id @default(uuid())
  postId          String
  itemName        String
  targetQuantity  Float
  currentQuantity Float         @default(0)
  unit            String?
  status          SupportStatus @default(Open)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum CauseEnum {
  educationAndChildren
  healthAndMedical
  disasterRelief
  environmentAndClimate
  povertyAndHunger
  communityDevelopment
  livelihoodAndSkillsTraining
  animalWelfare
  others
}

enum Priority {
  High
  Medium
  Low
}

enum PostStatus {
  Pending
  Approved
  Unapproved
  Edited
  Deleted
}

enum SupportStatus {
  Open
  Closed
}

enum UserRole {
  donor
  ngo
  admin
}

enum AccountStatus {
  pending
  approved
  rejected
  active
}