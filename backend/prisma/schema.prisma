generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id         String   @id @default(uuid())
  orgName    String
  email      String   @unique
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Post {
  id            String        @id @default(uuid())
  orgId         String        @default("tempID")
  projectName   String
  description   String?
  category      String?
  causes        CauseEnum[]
  location      String?
  priority      Priority      @default(Medium)
  overallStatus PostStatus    @default(Draft)
  createdAt     DateTime      @default(now())
  startDate     String?
  endDate       String?
  startTime     String?
  endTime       String?
  monetaryEnabled       Boolean       @default(false)
  monetaryTargetAmount  Float?
  monetaryCurrentAmount Float         @default(0)
  monetaryStatus        SupportStatus @default(Open)
  volunteerEnabled      Boolean       @default(false)
  volunteerTargetCount  Int?
  volunteerCurrentCount Int           @default(0)
  volunteerStatus       SupportStatus @default(Open)
  inKindItems PostInKindItem[]
}

model PostInKindItem {
  id              String        @id @default(uuid())
  postId          String
  itemName        String
  targetQuantity  Float
  currentQuantity Float         @default(0)
  unit            String?
  status          SupportStatus @default(Open)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
}

enum CauseEnum {
  educationAndChildren
  healthAndMedical
  disasterRelief
  environmentAndClimate
  povertyAndHunger
  communityDevelopment
  livelihoodAndSkillsTraining
  animalWelfare
  others
}

enum Priority {
  High
  Medium
  Low
}

enum PostStatus {
  Draft
  Published
}

enum SupportStatus {
  Open
  Closed
}